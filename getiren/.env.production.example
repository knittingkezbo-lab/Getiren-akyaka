# ============================================================================
#  ÜRETİM ORTAMI ŞABLONU — getirenakyaka.com
#  Sunucuda `.env` olarak kopyalanıp doldurulur. Gerçek sırlar ASLA repoya girmez.
#  Doldurduktan sonra: php artisan key:generate && php artisan config:cache
# ============================================================================

APP_NAME="Getiren Akyaka"
APP_ENV=production
APP_KEY=                                   # php artisan key:generate ile üretilir
APP_DEBUG=false                            # üretimde MUTLAKA false
APP_URL=https://getirenakyaka.com

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=warning                          # üretimde debug değil

# Kayıtta e-posta doğrulama AÇIK (gerçek müşteri)
AUTH_EMAIL_VERIFICATION=true

# --- Veritabanı (gerçek sunucu bilgileri) ---
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- Oturum güvenliği (HTTPS zorunlu) ---
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.getirenakyaka.com
SESSION_SECURE_COOKIE=true                 # yalnızca https üzerinden çerez
SESSION_SAME_SITE=lax

# --- İlk yönetici (php artisan db:seed --class=AdminSeeder) ---
ADMIN_NAME="Ad Soyad"
ADMIN_EMAIL=yonetici@getirenakyaka.com
ADMIN_PASSWORD=                            # güçlü bir şifre — seed sonrası panelden değiştirin

# --- İnceleme hesapları (PayTR incelemesi için; php artisan db:seed --class=ReviewSeeder) ---
# İnceleme bitince bu hesapları silin. Otomatik seed'e girmez.
REVIEW_EMAIL=inceleme@getirenakyaka.com
REVIEW_PASSWORD=

# --- İşletme/şirket kimlik bilgisi (hukuki sayfalar + iletişim) ---
COMPANY_NAME="Getiren Akyaka"
COMPANY_LEGAL_NAME=
COMPANY_OWNER=
COMPANY_TYPE="şahıs işletmesi"
COMPANY_TAX_OFFICE=
COMPANY_TAX_NO=
COMPANY_MERSIS=
COMPANY_ETBIS=
COMPANY_NACE=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=iletisim@getirenakyaka.com
COMPANY_KEP=
COMPANY_WEBSITE=getirenakyaka.com
COMPANY_HOURS="Her gün 09:00–21:00"
COMPANY_SERVICE_AREAS="Akyaka, Gökova, Akçapınar (Muğla)"

# Avukat metinleri onaylayınca false yap → "TASLAK" bandı kalkar
LEGAL_DRAFT=true

# --- Ödeme ---
# ⚠️ PayTR entegrasyonu HENÜZ TAMAMLANMADI (PayTRGateway iskelet; authorize/capture/void
#    çağrıları bağlanmadı). PAYMENT_DRIVER=paytr yazarsan HİÇBİR sipariş oluşmaz.
#    Ayrıca 'demo' sürücüsü üretimde reddedilir (gerçek tahsilat yapmaz) — yani şu an
#    bu uygulama gerçek ödemeyle CANLIYA ALINAMAZ. Entegrasyon bitince burayı doldur.
PAYMENT_DRIVER=
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=true                       # uçtan uca test edilmeden false yapma
PAYTR_CALLBACK_URL=https://getirenakyaka.com/odeme/paytr/geri-bildirim
# Callback yolu imza doğrulaması tamamlanana kadar KAPALI kalmalı (kapalıyken 404)
PAYTR_CALLBACK_ENABLED=false

# --- Gerçek e-posta (doğrulama mailleri için; Mailpit değil) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="bildirim@getirenakyaka.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Kuyruk: e-posta/bildirimleri isteğe göre worker'a taşı ---
QUEUE_CONNECTION=sync                      # ileride database + worker'a geçilebilir
CACHE_STORE=database
FILESYSTEM_DISK=local

# --- Canlı güncelleme (Reverb) — BAŞLANGIÇTA KAPALI ---
# Reverb'siz, yalın başlıyoruz. Bildirimler DB + e-postaya gider; anlık push yok.
# Talep gelip VDS büyüyünce açmak için: LIVE_UPDATES=true + VITE_LIVE_UPDATES=true +
# BROADCAST_CONNECTION=reverb + REVERB_* doldur + reverb servisini çalıştır + asset build.
LIVE_UPDATES=false
VITE_LIVE_UPDATES=false
BROADCAST_CONNECTION=null

# (Reverb açılınca kullanılacak — şimdilik boş kalabilir)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Tarayıcı wss:// ile bağlanır (nginx → reverb reverse proxy 443)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="getirenakyaka.com"
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

VITE_APP_NAME="${APP_NAME}"
