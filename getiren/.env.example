APP_NAME="Getiren Akyaka"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Kayıtta e-posta doğrulama (gerçek mail sağlayıcısı bağlanınca true yapılır)
AUTH_EMAIL_VERIFICATION=false

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=getiren
DB_USERNAME=getiren
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Canlı güncelleme (Reverb). Reverb'siz başlamak için: LIVE_UPDATES=false + VITE_LIVE_UPDATES=false
# + BROADCAST_CONNECTION=null + asset build. Bildirimler yine DB + e-postaya gider.
LIVE_UPDATES=true

# Ödeme sağlayıcısı sürücüsü (config/payments.php). 'demo' gerçek para hareketi yapmaz;
# PayTR anahtarları + "Ön Provizyon" yetkisi gelince PAYMENT_DRIVER=paytr yapılır.
PAYMENT_DRIVER=demo

# PayTR (yalnızca PAYMENT_DRIVER=paytr iken kullanılır) — mağaza panelinden alınır
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=true
# PAYTR_CALLBACK_URL=https://getirenakyaka.com/odeme/paytr/geri-bildirim

# Üretim yöneticisi (yalnızca APP_ENV=production seed'inde kullanılır)
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# İnceleme hesapları (PayTR vb.) — sadece `php artisan db:seed --class=ReviewSeeder` ile
REVIEW_EMAIL=
REVIEW_PASSWORD=

# İşletme/şirket bilgisi (config/company.php) — hukuki sayfalar + iletişim burayı kullanır
# Hassas veriler yalnızca gerçek .env'de durur, repoya girmez.
COMPANY_NAME="Getiren Akyaka"
COMPANY_LEGAL_NAME=
COMPANY_OWNER=
COMPANY_TYPE="şahıs işletmesi"
COMPANY_TAX_OFFICE=
COMPANY_TAX_NO=
COMPANY_MERSIS=
COMPANY_ETBIS=
COMPANY_NACE=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_KEP=
COMPANY_WEBSITE=getirenakyaka.com
COMPANY_HOURS="Her gün 09:00–21:00"
COMPANY_SERVICE_AREAS="Akyaka, Gökova, Akçapınar (Muğla)"

# Hukuki metinler avukatça kesinleşince false → "TASLAK" bandı kalkar
LEGAL_DRAFT=true

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="bildirim@getiren.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WebSocket (Laravel Reverb) — canlı zil + sipariş takibi
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Sunucu tarafı push (app → reverb): Docker servis adı + iç port
REVERB_HOST="reverb"
REVERB_PORT=8080
REVERB_SCHEME=http
# Reverb sunucusunun bağlanma adresi (konteyner içi)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Tarayıcı tarafı (Echo): host'a maplenen port
VITE_LIVE_UPDATES=true
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="localhost"
VITE_REVERB_PORT=8085
VITE_REVERB_SCHEME=http
